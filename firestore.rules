rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} { allow read, write: if false; }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && (request.auth.token.email == "serena.serena0395@gmail.com" && request.auth.token.email_verified == true); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Connection test
    match /test/connection { allow read: if true; }

    // --- Users ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'displayName']) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() <= 30 &&
             data.displayName is string && data.displayName.size() <= 50;
    }

    match /social_users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'followingCount', 'followersCount', 'postsCount'])
      );
    }

    // --- Posts ---
    function isValidPost(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['text', 'image', 'video', 'poll', 'ad'] &&
             (!('content' in data) || (data.content is string && data.content.size() <= 10000)) &&
             (!('mediaUrls' in data) || (data.mediaUrls is list && data.mediaUrls.size() <= 10));
    }

    match /social_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPost(incoming()) && isValidId(postId);
      allow update: if (isOwner(existing().userId) || isAdmin()) && isValidPost(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaUrls', 'isPinned', 'isSponsored', 'likesCount', 'commentsCount', 'score'])
      );
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // --- Polls ---
    function isValidPoll(data) {
      return data.keys().hasAll(['id', 'question', 'options', 'createdBy']) &&
             data.createdBy == request.auth.uid &&
             data.options is list && data.options.size() >= 2 && data.options.size() <= 6;
    }

    match /social_polls/{pollId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPoll(incoming());
      allow update: if isSignedIn() && (
        // Voting logic: only incrementing votes count
        incoming().diff(existing()).affectedKeys().hasOnly(['totalVotes', 'options'])
      );
    }

    // --- Comments ---
    function isValidComment(data) {
      return data.keys().hasAll(['id', 'postId', 'userId', 'text', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() <= 2000;
    }

    match /social_comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidComment(incoming());
      allow update: if (isOwner(existing().userId) || isAdmin()) && isValidComment(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['text', 'likesCount'])
      );
      allow delete: if (isOwner(existing().userId) || isAdmin());
    }

    // --- Notifications ---
    match /social_notifications/{notifId} {
      allow read: if isOwner(resource.data.recipientId);
      allow update: if isOwner(resource.data.recipientId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow create: if isSignedIn(); // Simplified: anyone can trigger a notification if they interact
    }

    // --- Social Actions (Follows, Likes, Saved) ---
    match /social_followers/{id} {
      allow read: if isSignedIn();
      allow create, delete: if isOwner(incoming().followerId) || isOwner(existing().followerId);
    }

    match /social_likes/{id} {
      allow read: if isSignedIn();
      allow create, delete: if isOwner(incoming().userId) || isOwner(existing().userId);
    }

    match /social_saved/{id} {
      allow read: if isOwner(resource.data.userId);
      allow create, delete: if isOwner(incoming().userId) || isOwner(existing().userId);
    }

    // --- Profiles (Legacy/Global) ---
    match /profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Tenants (Legacy/CRM) ---
    match /tenants/{tenantId} {
      allow read, write: if isSignedIn() && (
        exists(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid)) ||
        tenantId == "tenant_" + request.auth.uid ||
        isAdmin()
      );
      
      match /{document=**} {
        allow read, write: if isSignedIn() && (
          exists(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid)) ||
          tenantId == "tenant_" + request.auth.uid ||
          isAdmin()
        );
      }
    }

    // Legacy Support (Admin only root access)
    match /tenants_backup/{tenantId}/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
